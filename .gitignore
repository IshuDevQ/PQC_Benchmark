# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Build and packaging artifacts
build/
dist/
*.egg-info/
.eggs/
liboqs/

# Generated benchmark artifacts
results/raw/*.json
results/processed/*.json
results/processed/*.csv
plots/*.png

# Keep the output directory structure
!results/raw/.gitkeep
!results/processed/.gitkeep
!plots/.gitkeep
